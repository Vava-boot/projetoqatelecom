# ──────────────────────────────────────────────────────────────
#  QA Telecom Monitor — Variáveis de Ambiente (Back-end)
#  Copie este arquivo para .env e preencha os valores reais
#  NUNCA suba o arquivo .env para o repositório
# ──────────────────────────────────────────────────────────────

# Chave da OpenRouter
# Obtenha em: https://openrouter.ai/keys
# A chave deve começar com: sk-or-v1-
OPENROUTER_API_KEY=sk-or-v1-SUA_CHAVE_AQUI

# Porta do servidor (Railway injeta automaticamente — não altere em produção)
PORT=3001

# URL do front-end (usada no CORS e no HTTP-Referer da OpenRouter)
# Desenvolvimento:
ALLOWED_ORIGINS=http://localhost:5173
# Produção (exemplo):
# ALLOWED_ORIGINS=https://qa-telecom-jzym.vercel.app
