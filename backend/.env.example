# ──────────────────────────────────────────────
#  QA Telecom — Variáveis de Ambiente (Back-end)
#  Copie este arquivo para .env e preencha os valores.
#  NUNCA commite o arquivo .env.
# ──────────────────────────────────────────────

# Obrigatória — chave da sua conta em https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-SUA_CHAVE_AQUI

# Porta do servidor (o Render define isso automaticamente em produção)
PORT=3001

# Origens permitidas pelo CORS (separe por vírgula se houver mais de uma).
# Coloque aqui a URL EXATA do seu front-end (Vercel), sem barra no final.
ALLOWED_ORIGINS=http://localhost:5173

# ── Persistência (opcional) ────────────────────────────────────────────
# Se não definida, o backend usa um repositório em memória (dados somem a
# cada reinício — ótimo para testar, não recomendado para produção real).
# No Render, crie um banco Postgres gerenciado e cole a "Internal Database
# URL" aqui.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# ── Modelos (opcional — já vêm com um bom padrão) ──────────────────────
# MODEL_EVAL=anthropic/claude-haiku-4.5
# MODEL_STT=openai/whisper-1
# APP_REFERER=https://seu-frontend.vercel.app
# APP_TITLE=QA Telecom Monitor
